# App (from Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Migrations (from Supabase Dashboard → Account → Access Tokens)
# Required for: npm run db:link, npm run db:push
SUPABASE_ACCESS_TOKEN="your-personal-access-token"

# Optional: for non-interactive db:link (from Project Settings → Database)
SUPABASE_DB_PASSWORD="your-database-password"

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY="pk_..."
